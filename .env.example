# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=qad
POSTGRES_USER=qad_user
POSTGRES_PASSWORD=changeme                  # CHANGE THIS in production

# ── n8n ───────────────────────────────────────────────────────
N8N_HOST=localhost                          # Set to your domain in production
N8N_ENCRYPTION_KEY=qad-change-this-32char-secret-key   # CHANGE THIS
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=qadpass123          # CHANGE THIS in production
WEBHOOK_URL=http://localhost:5678/          # Set to public URL in production
GENERIC_TIMEZONE=America/Los_Angeles

# ── n8n API (populated after first login) ─────────────────────
N8N_API_URL=http://localhost:5678
N8N_API_KEY=
