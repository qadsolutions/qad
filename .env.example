# QAD Solutions — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.
# Update this file whenever you add a new environment variable.

# =============================================================================
# SUPABASE — Data layer (PostgreSQL + pgvector + Auth + Storage)
# =============================================================================

# Safe to expose in browser (NEXT_PUBLIC_ prefix is intentional — see SECURITY.md)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder

# SERVER-SIDE ONLY — bypasses ALL RLS — NEVER add NEXT_PUBLIC_ prefix (see SECURITY.md)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder

# =============================================================================
# INFERENCE — LLM provider
# =============================================================================

# "groq" = prototype (synthetic data only) | "ollama" = production (see SECURITY.md)
INFERENCE_PROVIDER=groq

# Groq free tier — Llama 3.3 70B — SYNTHETIC DATA ONLY — remove in production
GROQ_API_KEY=gsk_placeholder

# Ollama via Cloudflare Tunnel — required when INFERENCE_PROVIDER=ollama
OLLAMA_BASE_URL=https://your-tunnel.trycloudflare.com

# LLM model name (must be pulled in Ollama: docker exec qad-ollama ollama pull llama3.2)
LLM_MODEL=llama3.2

# =============================================================================
# EMBEDDINGS — Ollama nomic-embed-text (768-dim vectors)
# =============================================================================

# Usually the same as OLLAMA_BASE_URL
OLLAMA_EMBED_URL=https://your-tunnel.trycloudflare.com

# Embedding model (must be pulled: docker exec qad-ollama ollama pull nomic-embed-text)
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# APPLICATION
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================================
# RATE LIMITING (issue #62)
# =============================================================================

# Per-tenant/per-user RAG query cap. Backed by the rate_limit_counters table +
# increment_rate_limit() (Postgres, not Redis) — durable and multi-instance-correct.
RATE_LIMIT_QUERIES_PER_MINUTE=10

# Per-tenant daily upload cap. Counts the tenant's documents rows in the trailing 24h.
RATE_LIMIT_UPLOADS_PER_DAY=50

# =============================================================================
# DOCUMENT INGESTION
# =============================================================================

# Max file size in bytes (50MB default)
MAX_FILE_SIZE_BYTES=52428800

# Chunk size in tokens
CHUNK_SIZE_TOKENS=512

# Overlap between consecutive chunks in tokens
CHUNK_OVERLAP_TOKENS=64

# Number of chunks retrieved per RAG query (top-k)
RAG_TOP_K=5

# HNSW candidate window for tenant post-filter recall (issue #96).
# The shared multi-tenant HNSW index post-filters by tenant_id; if ef_search is
# too small, the traversal exhausts the candidate window before finding k
# qualifying chunks, silently returning fewer than top-k results.
# 100 = 2.5× the pgvector built-in default (40) — sufficient for most workloads.
# Increase if tenants return fewer than top-k results at scale. Each doubling
# roughly doubles traversal work; benchmark before exceeding ~400.
# Performance target: < 200ms per vector search query.
RAG_HNSW_EF_SEARCH=100

# Token budget for the retrieved-context section of a RAG prompt (issue #29).
# Bounds prompt size so a large top-k can't overflow the inference context window.
RAG_CONTEXT_TOKEN_BUDGET=3000

# =============================================================================
# LOCAL DEV — Docker services (not used in production)
# =============================================================================

POSTGRES_DB=qad
POSTGRES_USER=qad_user
POSTGRES_PASSWORD=changeme

N8N_HOST=localhost
N8N_ENCRYPTION_KEY=qad-change-this-32char-secret-key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=qadpass123
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Los_Angeles

# =============================================================================
# LOCAL TEST DATABASE — Vitest integration suite (not used in production)
# =============================================================================
#
# Integration tests need a Postgres WITH the pgvector extension (the embeddings
# migration runs `CREATE EXTENSION vector`), which the dev Postgres (alpine, :5433)
# lacks. You normally do NOTHING here: `pnpm test` runs a pretest hook
# (scripts/ensure-test-db.mjs) that auto-generates the gitignored .env.test.local
# below and starts the pgvector container (docker compose --profile test up -d
# qad-test-db). Vitest auto-loads .env.test.local (vitest.config.ts). CI provisions
# its own pgvector service and sets DATABASE_URL itself, so this is local-only.
# Host 5544 avoids the dev DB (5433) and any native Postgres on 5432.
#
# DATABASE_URL=postgresql://qad_user:testpassword@127.0.0.1:5544/qad_test
